# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ─── Solana ───────────────────────────────────────────────────────────────────
# Default is devnet public RPC (rate limited). For production use a dedicated RPC.
SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string. Required for all write endpoints.
API_KEY=change-me-to-a-secure-random-string

# ─── Encryption ───────────────────────────────────────────────────────────────
# MUST be exactly 32 bytes, base64-encoded.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENT_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ─── Receiver wallet ──────────────────────────────────────────────────────────
# A devnet wallet address to receive test transfers. Can be any valid devnet pubkey.
RECEIVER_PUBLIC_KEY=REPLACE_WITH_DEVNET_PUBKEY

# ─── SPL token ────────────────────────────────────────────────────────────────
SPL_MINT_DECIMALS=6

# ─── Jupiter swap ─────────────────────────────────────────────────────────────
JUPITER_SLIPPAGE_BPS=50
# Small amount: 10000 lamports = 0.00001 SOL
JUPITER_SWAP_AMOUNT_LAMPORTS=10000
# SOL (wrapped) - standard WSOL mint
JUPITER_INPUT_MINT=So11111111111111111111111111111111111111112
# USDC on devnet (if no route found, action is marked SKIPPED_NO_ROUTE)
# You can also use: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v (mainnet USDC for ref)
# For devnet USDC try: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
JUPITER_OUTPUT_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ─── Harness ──────────────────────────────────────────────────────────────────
# Default interval for harness loop in milliseconds
HARNESS_INTERVAL_MS=30000

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your web app origin in production
CORS_ORIGIN=http://localhost:3000
